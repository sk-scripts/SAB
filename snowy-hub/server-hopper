-- // 9. Main Loop
task.spawn(function()
    task.wait(5)
    while task.wait(3) do
        if Options.IsHopping then break end
        
        -- Anti-Friend
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= Player and p:IsFriendsWith(Player.UserId) then
                StatusLabel.Text = "Status: FRIEND DETECTED! HOPPING..."
                ServerHop() return
            end
        end

        local foundItems = {}
        local hasTarget = false
        
        -- Improved Scanner Logic
        for _, v in pairs(Workspace:GetDescendants()) do 
            if v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
                local genLabel, nameLabel, rarLabel
                local container = v.Parent
                
                for _, obj in pairs(v:GetDescendants()) do
                    if obj:IsA("TextLabel") then
                        local name = obj.Name:lower()
                        local text = obj.Text
                        local lowText = text:lower()

                        -- Prioritize Generation (/s) over Price ($)
                        if lowText:find("/s") or name:find("generation") or name:find("income") then
                            genLabel = obj
                        elseif not genLabel and (text:find("%$") or text:find("gen")) then
                            if not lowText:find("price") and not lowText:find("cost") then
                                genLabel = obj
                            end
                        elseif name:find("rarity") or text:find("Common") or text:find("Rare") then
                            rarLabel = obj
                        elseif name:find("name") or name:find("display") then
                            nameLabel = obj
                        end
                    end
                end
                
                if genLabel then
                    local genStr = genLabel.Text
                    -- Use Parent Name if Label Name is missing or generic "Item"
                    local nameStr = nameLabel and nameLabel.Text or container.Name
                    if nameStr == "Overhead" or nameStr == "BillboardGui" or nameStr == "Label" then
                        nameStr = container.Parent.Name
                    end
                    
                    local rarStr = rarLabel and rarLabel.Text or "None"
                    local genNum = parseGen(genStr)
                    
                    if genNum > 0 then
                        local key = nameStr .. "|" .. genStr
                        if not foundItems[key] then
                            foundItems[key] = {count = 1, name = nameStr, gen = genStr, rar = rarStr}
                        else
                            foundItems[key].count = foundItems[key].count + 1
                        end
                        
                        if genNum >= Options.MinGeneration then 
                            if Options.MinRarity == "" or rarStr:lower():find(Options.MinRarity) then hasTarget = true end 
                        end
                    end
                end
            end
        end
        
        local animals = {}
        for _, data in pairs(foundItems) do table.insert(animals, string.format("x%d %s %s", data.count, data.name, data.gen)) end
        
        local summary = #animals > 0 and table.concat(animals, "\n") or "No items found."
        StatusLabel.Text = "JOB: " .. (game.JobId:sub(1,8)) .. "\n" .. (#animals .. " items found") .. "\n\n" .. summary
        if hasTarget then StatusLabel.TextColor3 = Color3.fromRGB(80, 255, 140) end
        
        task.spawn(function() SendWebhook(summary, hasTarget) end)
        
        if hasTarget then 
            Options.AutoHop = false break 
        elseif Options.AutoHop then 
            task.wait(2)
            ServerHop() break 
        end
    end
end)
