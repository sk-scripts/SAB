local function SaveBlacklist() 
    pcall(function() writefile(BlacklistFile, HttpService:JSONEncode(VisitedServers)) end) 
end

local function LoadBlacklist()
    pcall(function() 
        if isfile and isfile(BlacklistFile) then 
            local decoded = HttpService:JSONDecode(readfile(BlacklistFile))
            for k, v in pairs(decoded) do VisitedServers[k] = v end
        end 
    end)
end

