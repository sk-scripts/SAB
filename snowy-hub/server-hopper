-- // 5. Utilities
local function parseGen(str)
    if not str then return 0 end
    str = tostring(str):upper():gsub(",", "."):gsub("%%", ""):gsub("%$", ""):gsub("/S", "")
    local n = tonumber(str:match("[%d%.]+")) or 0
    local s = str:match("[KMBT]")
    if s == "K" then return n * 1000 
    elseif s == "M" then return n * 1000000 
    elseif s == "B" then return n * 1000000000 
    elseif s == "T" then return n * 1000000000000 
    end
    return n
end

-- // 6. Webhook
local function SendWebhook(animalSummary, hasTarget)
    if not WebhookURL or WebhookURL == "" then return end
    local pingString = ""
    if hasTarget then for _, id in pairs(Pings) do pingString = pingString .. "<@" .. id .. "> " end end
    local data = {
        ["content"] = pingString,
        ["embeds"] = {{
            ["description"] = "```" .. animalSummary .. "```",
            ["color"] = hasTarget and 0x50FF80 or 0x508CFF,
            ["footer"] = {["text"] = "Powered by .gg/JW4qTsM2fS | Job: " .. (game.JobId:sub(1,8))},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    local payload = HttpService:JSONEncode(data)
    local request = syn and syn.request or http_request or request or http.request or (fluxus and fluxus.request)
    if request then
        request({ Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload })
    else
        pcall(function() HttpService:PostAsync(WebhookURL, payload) end)
    end
end

-- // 7. Hopper
local function ServerHop()
    if Options.IsHopping then return end Options.IsHopping = true
    if StatusLabel then StatusLabel.Text = "Status: FINDING NEW SERVER..." end
    LoadBlacklist()
    
    local success, err = pcall(function()
        local response = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
        local servers = HttpService:JSONDecode(response).data
        local possible = {}
        for _, v in ipairs(servers) do 
            if v.playing < v.maxPlayers and v.id ~= game.JobId and not VisitedServers[v.id] then 
                table.insert(possible, v.id) 
            end 
        end
        
        if #possible > 0 then 
            local target = possible[math.random(1, #possible)] 
            VisitedServers[target] = os.time() 
            SaveBlacklist() 
            StatusLabel.Text = "Status: TELEPORTING..."
            TeleportService:TeleportToPlaceInstance(game.PlaceId, target, Player) 
            task.wait(5)
            Options.IsHopping = false -- Retry if teleport failed
        else 
            VisitedServers = {} -- Reset if no new servers
            SaveBlacklist() 
            TeleportService:Teleport(game.PlaceId) 
        end
    end)
    if not success then Options.IsHopping = false end
end

